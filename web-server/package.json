{
  "name": "web-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build-proto": "pbjs -t static-module -w es6 -o src/proto.js ../proto/main.proto",
    "install-wasm-js": "npm i ../wasm-js",
    "build-wasm-rs": "wasm-pack build ../wasm-rs --target web",
    "install-wasm-rs": "npm i ../wasm-rs/pkg",
    "build-deps": "npm run build-proto && npm run install-wasm-js && npm run build-wasm-rs && npm run install-wasm-rs",
    "predev": "npm run build-deps",
    "dev": "vite",
    "prebuild": "npm run build-deps",
    "build": "vite build"
  },
  "devDependencies": {
    "vite": "^8.0.4"
  },
  "dependencies": {
    "protobufjs-cli": "^2.0.1",
    "wasm-js": "file:../wasm-js",
    "wasm-rs": "file:../wasm-rs/pkg"
  }
}
